APP_NAME=LangGraph Builder Team
APP_ENV=local
QUALITY_THRESHOLD=75
POSTGRES_DB=builder
POSTGRES_USER=builder
POSTGRES_PASSWORD=builder
POSTGRES_DSN=postgresql://builder:builder@postgres:5432/builder
POSTGRES_CHECKPOINTER_ENABLED=true
QDRANT_URL=http://qdrant:6333
PROJECT_MEMORY_COLLECTION=project_memory
GLOBAL_MEMORY_COLLECTION=global_meta_knowledge
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=LangGraph Builder Team
LANGCHAIN_TRACING_V2=false
MCP_SERVERS_JSON=
AGENT_PROTOCOL_ENABLED=true
LANGCONNECT_URL=
OPEN_SWE_URL=
AUTH_ENABLED=false
AUTH_USERNAME=admin
AUTH_PASSWORD=
AUTH_SESSION_SECRET=change-me
AUTH_COOKIE_NAME=lgb_session
